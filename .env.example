# ====================================
# MongoDB Atlas (Free Cloud Database)
# Get from: https://cloud.mongodb.com → Connect → Drivers → Node.js
# ====================================
MONGODB_URI=mongodb+srv://shopcloud-user:<password>@shopcloud.xxxxx.mongodb.net/?retryWrites=true&w=majority

# ====================================
# Azure Blob Storage
# Get from: Azure Portal → Storage Account → Access keys → Connection string
# Region used: eastasia
# ====================================
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=shopcloudpranavstore;AccountKey=your-key;EndpointSuffix=core.windows.net

# ====================================
# Azure Cognitive Services - Computer Vision
# Get from: Azure Portal → Computer Vision resource → Keys and Endpoint
# Region used: eastasia
# ====================================
AZURE_VISION_KEY=your-computer-vision-key
AZURE_VISION_ENDPOINT=https://eastasia.api.cognitive.microsoft.com/

# ====================================
# Azure Application Insights
# Get from: Azure Portal → Application Insights → Overview → Connection String
# Region used: eastasia
# ====================================
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://eastasia-0.in.applicationinsights.azure.com/

# ====================================
# Azure Language Service (Sentiment Analysis + AI Chat)
# Get from: Azure Portal → Language resource → Keys and Endpoint
# CLI: az cognitiveservices account create --kind TextAnalytics --sku F0 --location eastasia
# Region used: eastasia
# ====================================
AZURE_LANGUAGE_KEY=your-language-key
AZURE_LANGUAGE_ENDPOINT=https://eastasia.api.cognitive.microsoft.com/

# ====================================
# Azure Translator
# Get from: Azure Portal → Translator resource → Keys and Endpoint
# CLI: az cognitiveservices account create --kind TextTranslation --sku F0 --location eastasia
# Region used: eastasia
# ====================================
AZURE_TRANSLATOR_KEY=your-translator-key
AZURE_TRANSLATOR_REGION=eastasia

# ====================================
# App Config
# ====================================
PORT=5000
NODE_ENV=production
